{
  "name": "13-dead-end-drive",
  "version": "0.1.0",
  "description": "Multiplayer digital adaptation of 13 Dead End Drive — AI Hackathon Edition",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "vite",
    "dev:server": "npm run dev -w @ded/game-server",
    "dev:bot-ai": "cd services/bot-ai && uvicorn app.main:app --reload --port 8000",
    "dev:all": "concurrently -n client,server,bot -c blue,green,magenta \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:bot-ai\"",
    "build": "tsc --noEmit && vite build",
    "build:server": "npm run build -w @ded/game-server",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:bot-ai": "cd services/bot-ai && python3 -m pytest tests/ -q",
    "test:contract": "vitest run src/__tests__/contracts && npm run test:bot-ai",
    "lint:boundaries": "depcruise packages apps/game-server/src src/server src/client --config .dependency-cruiser.cjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "vitest": "^2.0.0",
    "dependency-cruiser": "^16.10.0"
  },
  "dependencies": {
    "@ded/engine": "*",
    "@ded/game-logic": "*",
    "@ded/network": "*",
    "@ded/types": "*",
    "colyseus.js": "^0.15.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.106.1",
    "canvas-confetti": "^1.9.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  }
}
