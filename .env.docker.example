# Docker Compose — copy to .env in the repo root (optional; defaults work for local play)
#
#   cp .env.docker.example .env
#   docker compose up --build
#
# Open http://localhost:8080

# Game server (Nest + Colyseus)
PORT=2567
NODE_ENV=development
AUTH_REQUIRED=false
BOT_AI_URL=http://bot-ai:8000
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Supabase — only required when NODE_ENV=production and AUTH_REQUIRED=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Client build-time URLs (browser reaches host ports, not Docker service names)
# Rebuild client after changing: docker compose build client
VITE_COLYSEUS_URL=ws://localhost:2567
VITE_BOT_SERVICE_URL=/bot-api
VITE_LOBBY_API_URL=/lobby-api
VITE_ONLINE_MULTIPLAYER=true

# Bot AI (optional LLM)
LLM_ENABLED=false
OPENAI_API_KEY=
BOT_DIFFICULTY_DEFAULT=NORMAL
